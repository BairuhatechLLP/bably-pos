<!DOCTYPE html
    PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml"
    xmlns:o="urn:schemas-microsoft-com:office:office">

<head>
    <meta http-equiv="Content-type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="date=no" />
    <meta name="format-detection" content="address=no" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="x-apple-disable-message-reformatting" />
    <link href="https://fonts.googleapis.com/css?family=Muli:400,400i,700,700i" rel="stylesheet" />
    <title>Tax GO Invoice</title>
</head>

<body style="width: 100%;align-content: center;margin: auto;">
    <div style="margin: 20px;">
        <table style="margin-top: 60px !important;margin: auto;width: 100%;">
            <tbody>
                <tr>
                    <td><b>
                            {{#userInfo.companyInfo.bname}}
                            {{userInfo.companyInfo.bname}}
                            {{/userInfo.companyInfo.bname}}
                            {{^userInfo.companyInfo.bname}}
                            Demo Business
                            {{/userInfo.companyInfo.bname}}
                        </b></td>
                    <td colspan="2"><b>
                            {{#userInfo.companyInfo.fulladdress}}
                            {{userInfo.companyInfo.fulladdress}}
                            {{/userInfo.companyInfo.fulladdress}}
                        </b></td>
                    <td style="text-align: center" rowspan="6"><img style="width: 140px; height: 80px;"
                            src="https://taxgo.s3.eu-west-1.amazonaws.com/logo/{{userInfo.companyInfo.logo}}" />
                    </td>
                </tr>
                <tr>
                    <td></td>
                    <td colspan="2">
                        {{#userInfo.defaultBankInfo.name}}
                        {{userInfo.defaultBankInfo.name}}
                        {{/userInfo.defaultBankInfo.name}}
                        <br />
                        {{#userInfo.defaultBankInfo.accountNumber}}
                        {{userInfo.defaultBankInfo.accountNumber}}
                        {{/userInfo.defaultBankInfo.accountNumber}}
                        <br />
                        {{#userInfo.defaultBankInfo.iban}}
                        {{userInfo.defaultBankInfo.iban}}
                        {{/userInfo.defaultBankInfo.iban}}

                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td></td>
                </tr>
                <tr>
                    <td></td>
                </tr>
                <tr>
                    <td><b>VAT Number</b></td>
                    <td><b>Telephone</b></td>
                    <td><b>E-mail</b></td>
                    <td></td>
                </tr>
                <tr>
                    <td>
                        {{#userInfo.companyInfo.taxregno}}
                        {{userInfo.companyInfo.taxregno}}
                        {{/userInfo.companyInfo.taxregno}}
                        {{^userInfo.companyInfo.taxregno}}
                        -
                        {{/userInfo.companyInfo.taxregno}}
                    </td>
                    <td>
                        {{#userInfo.phonenumber}}
                        {{userInfo.phonenumber}}
                        {{/userInfo.phonenumber}}
                        {{^userInfo.phonenumber}}
                        -
                        {{/userInfo.phonenumber}}
                    </td>
                    <td>
                        {{#userInfo.email}}
                        {{userInfo.email}}
                        {{/userInfo.email}}
                        {{^userInfo.email}}
                        -
                        {{/userInfo.email}}
                    </td>
                    <td></td>
                </tr>
            </tbody>
        </table>
        <hr>
        <table style="margin: auto;width: 100%;">
            <tbody>
                <tr>
                    <td width="25%"><b>Supplier Reference</b></td>
                    <td width="25%">
                        {{#supplier.reference}}
                        {{supplier.reference}}
                        {{/supplier.reference}}
                        {{^supplier.reference}}
                        -
                        {{/supplier.reference}}
                    </td>
                    <td width="25%"><b>Invoice No</b></td>
                    <td width="25%">
                        {{#purchase.invoiceno}}
                        {{purchase.invoiceno}}
                        {{/purchase.invoiceno}}
                        {{^purchase.invoiceno}}
                        -
                        {{/purchase.invoiceno}}
                    </td>
                </tr>
                <tr>
                    <td width="25%" style="vertical-align:super;"><b>Supplier Details</b></td>
                    <td width="25%">
                        {{#supplier.name}}
                        {{supplier.name}}
                        {{/supplier.name}}
                        <br />
                        {{#supplier.bname}}
                        {{supplier.bname}}
                        {{/supplier.bname}}
                        <br />
                        {{#supplier.email}}
                        {{supplier.email}}
                        {{/supplier.email}}
                    </td>
                    <td><b>Invoice Date</b></td>
                    <td>
                        {{#purchase.sdate}}
                        {{purchase.sdate}}
                        {{/purchase.sdate}}
                        {{^purchase.sdate}}
                        -
                        {{/purchase.sdate}}
                    </td>
                </tr>
                <tr>
                    <td style="vertical-align:super;"><b></b></td>
                    <td>
                    </td>
                    <td><b>Due Date</b></td>
                    <td>
                        {{#purchase.ldate}}
                        {{purchase.ldate}}
                        {{/purchase.ldate}}
                        {{^purchase.ldate}}
                        -
                        {{/purchase.ldate}}
                    </td>
                </tr>
                <tr>
                    <td style="vertical-align:super;"><b></b></td>
                    <td></td>
                    <td><b>Reference</b></td>
                    <td>{{purchase.reference}}</td>
                </tr>
            </tbody>
        </table>
        <table style="margin-top: 25px !important;margin: auto;width: 100%;">
            <tbody style="text-align: center;">
                <tr style="background: gray;color: white;text-align: center;font-size: 12px;">
                    <td style="height: 40px;" width="12%"><b>
                            Product/Service
                        </b></td>
                    <td width="12%"><b>
                            Description
                        </b></td>
                    <td width="12%"><b>Qty/Hrs</b></td>
                    <td width="12%"><b>Price/Rate</b></td>
                    <td width="12%"><b>Discount</b></td>
                    <td width="12%"><b>% GST/VAT</b></td>
                    <td width="12%"><b>GST/VAT</b></td>
                    <td width="12%"><b>Total</b></td>
                </tr>
                {{#inpurchase}}
                <tr style="font-size: 12px;">
                    <td>
                        {{#product.icode}}
                        {{product.icode}}
                        {{#product.idescription}}
                        - {{product.idescription}}
                        {{/product.idescription}}
                        {{/product.icode}}
                        {{^product.icode}}
                        {{#description}}
                        {{description}}
                        {{/description}}
                        {{/product.icode}}
                    </td>
                    <td>
                        {{#description}}
                        {{description}}
                        {{/description}}
                    </td>
                    <td>
                        {{#quantity}}
                        {{quantity}}
                        {{/quantity}}
                    </td>
                    <td>
                        {{#costprice}}
                        {{costprice}}
                        {{/costprice}}
                    </td>
                    <td>
                        {{#discount}}
                        {{discount}}
                        {{/discount}}
                        {{^discount}}
                        -
                        {{/discount}}
                    </td>
                    <td>
                        {{#vat}}
                        {{vat}}
                        {{/vat}}
                        {{^vat}}
                        -
                        {{/vat}}
                    </td>
                    <td>
                        {{#vatamt}}
                        {{vatamt}}
                        {{/vatamt}}
                        {{^vatamt}}
                        -
                        {{/vatamt}}
                    </td>
                    <td>
                        {{#total}}
                        {{countryInfo.symbol}}{{total}}
                        {{/total}}
                    </td>
                </tr>
                {{/inpurchase}}
            </tbody>
        </table>
        <hr>
        <table style="margin-top: 25px !important;margin: auto;width: 100%;">
            <tbody style="text-align: center;">

                <tr style="font-size: 12px;">
                    <td width="30%"></td>
                    <td width="30%"></td>
                    <td width="20%"><b>VAT</b></td>
                    <td width="20%"><b>
                            {{#vatTotal}}
                            {{vatTotal}}
                            {{/vatTotal}}
                        </b></td>
                </tr>
                <tr style="font-size: 12px;">
                    <td width="30%"></td>
                    <td width="30%"></td>
                    <td width="20%"><b>Net</b></td>
                    <td width="20%"><b>
                            {{#netTotal}}
                            {{netTotal}}
                            {{/netTotal}}
                        </b></td>
                </tr>
                <tr style="background: gray;color: white;text-align: center;font-size: 12px;">
                    <td style="height: 35px;" colspan="2" width="12%"></td>
                    <td width="5%"><b>Total</b></td>
                    <td width="5%" style="color: black;"><b>
                            {{#purchase.total}}
                            {{countryInfo.symbol}}{{purchase.total}}
                            {{/purchase.total}}
                        </b>

                    </td>
                </tr>
                {{#purchase.totalText}}
                <tr style="text-align:right">
                    <td colspan="4">({{purchase.totalText}})</td>
                </tr>
                {{/purchase.totalText}}
            </tbody>
        </table>
        <table style="border-spacing: 0px;margin-top: 10px !important;margin: auto;width: 100%;">
            <tbody style="text-align: center;">
                <tr style="border: none;background: lightgray;color: black;text-align: center;font-size: 12px;">
                    <td rowspan="2" width="52%" style="border: none;height: 60px;" colspan="2" width="12%">
                        <b>Invoice Descriptions</b>
                        <p style="text-align:justify;">
                            {{#purchase.quotes}}
                            {{purchase.quotes}}
                            {{/purchase.quotes}}</p>

                        <br>
                    </td>
                    <td width="12%" style="border-bottom: 1px solid gray;"><b>GST/VAT Rate</b></td>
                    <td width="12%" style="border-bottom: 1px solid gray;"><b>Net</b></td>
                    <td width="12%" style="border-bottom: 1px solid gray;"><b>GST/VAT</b></td>
                    <td width="12%" style="border-bottom: 1px solid gray;"><b>Total</b></td>
                </tr>
                <tr style="border: none;background: lightgray;color: black;text-align: center;font-size: 12px;">
                    <td width="12%" style="border: none;">
                        {{#vatRate}}
                        {{vatRate}}
                        {{/vatRate}}
                    </td>
                    <td width="12%" style="border: none;">
                        {{#netTotal}}
                        {{netTotal}}
                        {{/netTotal}}
                    </td>
                    <td width="12%" style="border: none;">
                        {{#vatTotal}}
                        {{vatTotal}}
                        {{/vatTotal}}
                    </td>
                    <td width="12%" style="border: none;">
                        {{#purchase.total}}
                        {{countryInfo.symbol}} {{purchase.total}}
                        {{/purchase.total}}
                    </td>
                </tr>
            </tbody>
        </table>
        {{#bankInfo.length}}
        <div>
            <p style="text-align: center;"><b>Payment Information</b></p>
        </div>
        <table style="margin-top: 25px !important;margin: auto;width: 100%;border: 1px solid black;">
            <tbody style="text-align: center;">
                <tr style="background: gray;color: black;text-align: center;font-size: 12px;">
                    <td style="height: 25px;" width="12%"><b>Bank Holder Name</b></td>
                    <td width="12%"><b>Account No</b></td>
                    <td width="12%"><b>Paid Method</b></td>
                    <td width="12%"><b>Amount</b></td>
                    <td width="12%"><b>Date</b></td>
                    <td width="12%"><b>Payment Type</b></td>
                </tr>
                {{#bankInfo}}
                <tr style="font-size: 12px;">
                    <td>
                        {{userInfo.firstname}} &nbsp; {{userInfo.lastname}}
                    </td>
                    <td>
                        {{bankInf.nominalcode}}
                    </td>
                    <td>
                        {{bankInf.paidmethod}}
                    </td>
                    <td>
                        {{amount}}
                    </td>
                    <td>
                        {{date}}
                    </td>
                    <td>
                        {{type}}
                    </td>
                </tr>
                {{/bankInfo}}

            </tbody>
        </table>
        {{/bankInfo.length}}
        <table style="width:100%">
            <tr style="width:100%;height:30px">
                <td style="width:50%"></td>
                <td style="width:50%"></td>
            </tr>
            <tr style="width:100%;height:70px">
                <td style="width:50%"></td>
                <td style="width:50%;border-top:1px solid gray;border-right:1px solid gray;border-left:1px solid gray">
                </td>
            </tr>
            <tr style="width:100%;height:10px">
                <td style="width:50%"></td>
                <td
                    style="width:50%;border-bottom:1px solid gray;border-right:1px solid gray;border-left:1px solid gray;padding-left:120px">
                    Authorised Signatory</td>
            </tr>
        </table>

        <div style="font-size: 10px; margin-top: 25px;">
            <p style="text-align: center;">Created by <a target="_blank"
                    href="https://www.taxgoglobal.com/">taxglobal.com</a></p>
        </div>
    </div>
</body>

</html>