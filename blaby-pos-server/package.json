{
  "name": "nest-sequelize-typescript",
  "engines": {
    "node": "18"
  },
  "version": "0.0.1",
  "description": "Nest + sequelize-typescript + JWT + Jest + Swagger",
  "keywords": [
    "nest",
    "nestjs",
    "nest.js",
    "sequelize",
    "sequelize-typescript",
    "orm",
    "nodejs",
    "node.js",
    "node",
    "typescript",
    "jwt",
    "jsonwebtoken",
    "passport",
    "swagger"
  ],
  "author": "Irshad",
  "license": "MIT",
  "scripts": {
    "build": "node --max-old-space-size=2048 ./node_modules/.bin/tsc -p tsconfig.build.json && copyfiles src/shared/templates/** dist/ && copyfiles src/mail/templates/** dist/",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "ts-node node_modules/.bin/sequelize db:migrate",
    "db:drop": "ts-node node_modules/.bin/sequelize db:drop",
    "db:create": "ts-node node_modules/.bin/sequelize db:create",
    "db:seed-dev": "ts-node node_modules/.bin/sequelize db:seed:all",
    "db:seed-prod": "ts-node node_modules/.bin/sequelize db:seed:all --seeders-path db/seeders-prod",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed-dev && npm run db:seed-prod",
    "start": "node dist/src/main.js",
    "startlocal": "nodemon",
    "start:debug": "nodemon --config nodemon-debug.json",
    "prestart:prod": "rimraf dist && npm run build",
    "start:prod": "node dist/src/main.js",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "seed": "ts-node -r tsconfig-paths/register src/seeder.ts",
    "seedData": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^1.8.1",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^9.2.1",
    "@nestjs/core": "^9.2.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^9.0.0",
    "@nestjs/platform-express": "^9.2.1",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^6.1.4",
    "@types/multer": "^1.4.11",
    "aws-sdk": "^2.925.0",
    "axios": "^1.2.2",
    "bcrypt": "^5.1.0",
    "blob-to-buffer": "^1.2.9",
    "cache-manager": "^5.5.3",
    "chrome-aws-lambda": "^10.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron": "^3.1.6",
    "currency-codes": "^2.1.0",
    "dotenv": "^16.0.3",
    "firebase-admin": "^12.1.0",
    "fs": "0.0.1-security",
    "handlebars": "^4.7.7",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.10.1",
    "jimp": "^0.22.10",
    "jsonwebtoken": "^8.5.1",
    "jspdf": "^2.5.1",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "mustache": "^4.2.0",
    "mysql2": "^2.3.3",
    "nodemailer": "^6.9.0",
    "number-to-words": "^1.2.4",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "path": "^0.12.7",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.14.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sequelize": "^6.28.0",
    "sequelize-cli": "^6.5.2",
    "sequelize-typescript": "^2.1.5",
    "stripe": "^14.20.0",
    "swagger-ui-express": "^4.6.0",
    "uniqid": "^5.4.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/blob-to-buffer": "^1.2.2",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/node": "^18.11.17",
    "@types/node-fetch": "^2.6.10",
    "@types/nodemailer": "^6.4.7",
    "@types/passport": "^1.0.11",
    "@types/passport-jwt": "^3.0.8",
    "@types/pdfkit": "^0.13.3",
    "@types/sequelize": "^4.28.14",
    "@types/supertest": "^2.0.12",
    "copyfiles": "^2.4.1",
    "nodemon": "^2.0.20",
    "prettier": "^2.8.1",
    "rimraf": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.1",
    "tslint": "^6.1.3",
    "typescript": "^4.9.4"
  }
}
